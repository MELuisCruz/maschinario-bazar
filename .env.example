# Maschinario · Bazar — POS · PRY-F-0001.1.8
# Plantilla de variables de entorno (CLAUDE.md §3).
# Copiar a `.env` y completar. El `.env` real NUNCA se versiona (ver .gitignore).

# --- Base de datos (PostgreSQL en docker-compose) ---
DATABASE_URL=postgresql+psycopg://pos:pos@localhost:5432/maschinario

# --- Mercado Pago Point (API de Orders) — secretos ---
MP_ACCESS_TOKEN=        # token de Mercado Pago (secreto)
MP_TERMINAL_ID=         # id de la terminal Point (Point Smart 2)

# --- Impresora térmica ESC/POS 80 mm (USB) ---
PRINTER_USB_VENDOR=     # idVendor de la impresora (hex, p. ej. 0x0416)
PRINTER_USB_PRODUCT=    # idProduct de la impresora (hex, p. ej. 0x5011)

# --- Negocio / fiscal ---
APP_BUSINESS_NAME=Maschinario · Bazar
APP_IVA_RATE=0.16

# --- Sesión (cookie firmada) ---
# OBLIGATORIO en producción: genera una cadena larga y aleatoria; NO la compartas.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Si se deja vacío, la app usa un valor de desarrollo conocido (INSEGURO).
APP_SECRET_KEY=

# --- Endurecimiento de sesión / login (opcional; valores por defecto razonables) ---
# Poner en true SOLO si sirves el POS detrás de HTTPS (con HTTP la cookie no viaja).
SESSION_HTTPS_ONLY=false
# Expiración de la sesión en segundos (default 12 h).
SESSION_MAX_AGE=43200
# Anti fuerza bruta del PIN: intentos fallidos antes de bloquear y duración (seg).
LOGIN_MAX_INTENTOS=5
LOGIN_BLOQUEO_SEG=300
